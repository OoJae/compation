# ============================================================
# Compation — environment configuration (documented template)
# Copy to `.env` and fill in. NEVER commit a real .env.
# ============================================================

# --- Azure OpenAI (the agent's runtime brain; Microsoft sponsor) ---
# Provision via Azure portal: create an Azure OpenAI resource, deploy a
# GPT-class model, then copy the values below. (Guided setup in Phase 0.5.)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=          # e.g. https://<resource-name>.openai.azure.com
AZURE_OPENAI_RESOURCE_NAME=     # <resource-name> (used by @ai-sdk/azure)
AZURE_OPENAI_DEPLOYMENT_NAME=   # the deployed model/deployment name
AZURE_OPENAI_API_VERSION=2024-10-21

# Dev fallback LLM (used only until Azure is provisioned; one-line swap to Azure).
# Leave empty in the demo build — Azure must be visibly on screen for judging.
FALLBACK_OPENAI_API_KEY=

# --- Injective agent wallet (DEDICATED, minimally funded, never personal) ---
INJECTIVE_PRIVATE_KEY=          # hex private key of the agent wallet (signs txs)
INJECTIVE_WALLET_ADDRESS=       # inj... address (also the ERC-8004 fee recipient)

# --- Network / market / executor selection ---
# COMPATION_MARKET picks the active MarketProfile from packages/shared/src/markets.ts
#   testnet:INJ_USDT (default dev)  |  testnet:BTC_USDT (backup)  |  mainnet:H100 (headline)
COMPATION_MARKET=testnet:INJ_USDT
# EXECUTOR picks the execution path: fake (safe default for dev) | sdk (real chain) | mcp (deferred)
# The CLI/dev default is fake; run real chain trades with `EXECUTOR=sdk` per command.
EXECUTOR=fake
# COMPATION_ROUTE selects the hedge route: dev (H100 index -> testnet INJ/USDC) | headline (H100 -> mainnet NVDA -> INJ)
COMPATION_ROUTE=dev
# HARD SAFETY GATE: mainnet state-changing trades are blocked unless this is exactly 'true'.
ALLOW_MAINNET_WRITES=false

# --- x402 micropayments (agent pays for its own compute in USDC) ---
X402_FACILITATOR_ENDPOINT=https://agents.injective.com/x402
USDC_SETTLEMENT_TIMEOUT_MS=2000

# --- Persistence ---
DATABASE_URL=file:./prisma/dev.db

# --- Frontend / API wiring ---
NEXT_PUBLIC_AGENT_API_URL=http://localhost:3001
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:3001/ws

# --- Risk-engine defaults (overridable per request) ---
HEDGE_RATIO_DEFAULT=0.8
LIQUIDATION_BUFFER_PERCENT=40
MAX_LEVERAGE=5
DEFAULT_LEVERAGE=2
SLIPPAGE_TOLERANCE_BPS=50
